APP_NAME=Government AI Agent Service
APP_ENV=development
APP_VERSION=0.1.0

HOST=0.0.0.0
PORT=8002

INTERNAL_API_KEY=dev-internal-key
DATABASE_URL=postgresql+psycopg2://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

PIPELINE_MODE=hybrid_v2
ENABLE_HYBRID_V2_FALLBACK=true
HYBRID_V2_DEBUG=true

ENABLE_GEMINI=true
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_ROUTER_ENABLED=true
GEMINI_ROUTER_MODEL=gemini-3.1-flash-lite-preview
GEMINI_ROUTER_TIMEOUT_MS=10000
GEMINI_ROUTER_RETRIES=1
GEMINI_ROUTER_RETRY_BACKOFF_MS=700
GEMINI_COMPOSER_ENABLED=true
CONVERSATION_CONTEXT_MAX_ROWS=20

PARSER_SERVICE_BASE_URL=https://your-ngrok-url.ngrok-free.dev
PARSER_SERVICE_TIMEOUT_MS=45000
PARSER_MODE=hybrid
PARSER_DEBUG=false
PARSER_HYBRID_ALLOWED_INTENTS=COMPARE_COUNTRIES,RANKING,TIME_SERIES,TREND_ANALYSIS,VALUE_LOOKUP,COVERAGE,RANK_BY_CHANGE,COMPARE_INDICATORS,ANOMALY_DETECTION
